## TA-oura metadata. Write is admin/sc_admin only (self-managed + Cloud).
## The shared person lookups now live in the `wearables` app (exported global);
## this add-on's props reference them by name and resolve them globally.

[]
access = read : [ * ], write : [ admin, sc_admin ]
export = system

## Normalization objects exported so the wearables app + dashboards inherit the
## canonical fields + dataset tags.
[props]
export = system

[eventtypes]
export = system

[tags]
export = system
